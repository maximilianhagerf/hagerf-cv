# Required environment variables for hagerf-cv
#
# Copy this file to .env and fill in the values before running the app.

# Supabase project URL (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=

# Supabase anonymous (public) API key
SUPABASE_ANON_KEY=

# Supabase service role key (server-side only, keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of this instance (e.g. https://cv.example.com)
PUBLIC_BASE_URL=

# Direct Postgres connection string used by Drizzle ORM
# (e.g. postgresql://postgres:password@db.abcdefgh.supabase.co:5432/postgres)
DATABASE_URL=
